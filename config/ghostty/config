font-family = "JetBrainsMono NF"
font-size = 15
theme = Vague
background-opacity = 0.85
background-blur = 50

keybind = global:ctrl+opt+cmd+t=toggle_quick_terminal
keybind = global:ctrl+cmd+t=new_window

macos-option-as-alt = true
keybind = alt+3=text:#

term = "xterm-256color"
auto-update = "download"
auto-update-channel = "tip"

config-file = ?~/dotfiles/config/ghostty/config.local
